# Flask
SECRET_KEY=change-me-to-random-string
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Site URL (used for links in emails etc.)
SITE_URL=http://your-server-ip

# Guacamole (internal API URL for Flask to talk to Guac)
GUAC_URL=http://localhost:8080/guacamole
GUAC_ADMIN_USER=guacadmin
GUAC_ADMIN_PASS=guacadmin
GUAC_DB_PASS=guac_db_pass_change_me

# Guacamole public URL (what students see — through nginx proxy)
GUAC_PUBLIC_URL=/guacamole

# Email (SMTP)
MAIL_SERVER=smtp.example.com
MAIL_PORT=465
MAIL_USERNAME=lab@example.com
MAIL_PASSWORD=change-me
MAIL_SENDER=lab@example.com

# LXD
LXD_NETWORK=lab-net
LXD_PROFILE=lab-student
LXD_IMAGE=images:debian/12
